<%- include('../../../includes/head', { title: lection.title, pageDescription: lection.description, pageStyles:
    pageStyles }) %>

    <%- include('../../../includes/navigation', { active: 'multimedijalne-aplikacije' }) %>

        <div class="lection-container">
            <!-- SIDEBAR -->
            <aside class="lection-sidebar">
                <%- include('../includes/navigation', { lections: lections, currentSlug: lection.slug }) %>
            </aside>

            <!-- CONTENT -->
            <main class="lection-content">

                <!-- ===============================
             LEKCIJA NIJE DOSTUPNA
        =============================== -->
                <% if (!lection.available) { %>

                    <div class="lection-locked">
                        <div class="lection-locked__icon">🔒</div>
                        <h1 class="lection-locked__title">Lekcija još nije dostupna</h1>
                        <p class="lection-locked__text">
                            Ova lekcija postaje dostupna
                            <strong>
                                <%= lection.formattedDate %>
                            </strong>.
                        </p>
                        <p class="lection-locked__text">Jedna lekcija se otključava svake nedelje.</p>
                        <a href="/multimedijalne-aplikacije" class="btn btn--primary btn--large">
                            Nazad na predmet
                        </a>
                    </div>

                    <!-- ===============================
             LEKCIJA JE DOSTUPNA
        =============================== -->
                    <% } else { %>

                        <article class="lection">

                            <!-- HEADER -->
                            <header class="lection__header">
                                <div class="lection__meta">
                                    <span class="lection__badge lection__badge--week">
                                        <span class="badge-icon">📅</span>
                                        Nedelja <%= lection.week %>
                                    </span>
                                    <span class="lection__badge lection__badge--date">
                                        <span class="badge-icon">📌</span>
                                        <%= lection.formattedDate %>
                                    </span>
                                </div>

                                <h1 class="lection__title">
                                    <%= lection.title %>
                                </h1>

                                <% if (lection.description) { %>
                                    <p class="lection__description">
                                        <%= lection.description %>
                                    </p>
                                    <% } %>
                                        <div class="project-note">

                                            ⚠️ Ovo je kratak pregled lekcije, nije zamena za prezentacije!

                                        </div>
                            </header>

                            <!-- ===============================
                     SADRŽAJ LEKCIJE
                =============================== -->
                            <div class="lection__content">

                                <!-- 1 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">1. Šta je signal?</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            Signal je fizička veličina koja prenosi informaciju.
                                            U multimediji najčešće radimo sa:
                                        </p>

                                        <ul class="styled-list">
                                            <li>Audio signalom (promena pritiska vazduha)</li>
                                            <li>Video signalom (promena intenziteta svetlosti)</li>
                                        </ul>

                                        <p>
                                            Matematički, signal se može posmatrati kao funkcija vremena:
                                        </p>

                                        <pre><code>
                x(t)
                            </code></pre>

                                        <p>
                                            gde je t kontinualna vremenska promenljiva.
                                        </p>

                                    </div>
                                </section>

                                <!-- 2 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">2. Analogni vs Digitalni signal</h2>
                                    <div class="lection-section__content">

                                        <h3>Analogni signal</h3>
                                        <ul class="styled-list">
                                            <li>Kontinualan u vremenu</li>
                                            <li>Kontinualan po amplitudi</li>
                                            <li>Beskonačno mnogo vrednosti</li>
                                        </ul>

                                        <h3>Digitalni signal</h3>
                                        <ul class="styled-list">
                                            <li>Diskretan u vremenu</li>
                                            <li>Diskretan po amplitudi</li>
                                            <li>Konačan broj nivoa</li>
                                        </ul>

                                        <div class="highlight-box">
                                            Digitalizacija = uzorkovanje + kvantizacija + binarno kodiranje
                                        </div>

                                    </div>
                                </section>

                                <!-- 3 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">3. Uzorkovanje (Sampling)</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            Uzorkovanje predstavlja merenje vrednosti analognog signala
                                            u diskretnim vremenskim intervalima.
                                        </p>

                                        <pre><code>
                x[n] = x(nT)
                            </code></pre>

                                        <p>
                                            gde je T period uzorkovanja, a fs = 1/T frekvencija uzorkovanja.
                                        </p>

                                        <h3>Nyquist-Shannon teorema</h3>

                                        <div class="highlight-box">
                                            fs ≥ 2 × fmax
                                        </div>

                                        <p>
                                            Frekvencija uzorkovanja mora biti najmanje dvostruko veća
                                            od maksimalne frekvencije signala.
                                        </p>

                                        <p>
                                            U suprotnom dolazi do <strong>aliasing efekta</strong>.
                                        </p>

                                    </div>
                                </section>

                                <!-- 4 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">4. Aliasing</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            Aliasing je pojava kada se visoke frekvencije
                                            pogrešno interpretiraju kao niže frekvencije.
                                        </p>

                                        <p>
                                            Nastaje kada:
                                        </p>

                                        <pre><code>
                fs &lt; 2 × fmax
                            </code></pre>

                                        <p>
                                            Rešenje:
                                        </p>

                                        <ul class="styled-list">
                                            <li>Povećanje frekvencije uzorkovanja</li>
                                            <li>Korišćenje niskopropusnog (anti-aliasing) filtera</li>
                                        </ul>

                                    </div>
                                </section>

                                <!-- 5 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">5. Kvantizacija</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            Kvantizacija je proces zaokruživanja kontinuirane amplitude
                                            na najbliži diskretni nivo.
                                        </p>

                                        <h3>Broj kvantizacionih nivoa:</h3>

                                        <pre><code>
                L = 2^n
                            </code></pre>

                                        <p>
                                            gde je n broj bitova.
                                        </p>

                                        <ul class="styled-list">
                                            <li>8 bit → 256 nivoa</li>
                                            <li>16 bit → 65.536 nivoa</li>
                                            <li>24 bit → 16.777.216 nivoa</li>
                                        </ul>

                                        <h3>Kvantizaciona greška</h3>

                                        <p>
                                            Razlika između stvarne vrednosti i kvantizovane vrednosti.
                                        </p>

                                        <div class="highlight-box">
                                            Veći broj bitova → manja greška → bolji kvalitet.
                                        </div>

                                    </div>
                                </section>

                                <!-- 6 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">6. Signal-to-Noise Ratio (SNR)</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            Odnos signal/šum definiše kvalitet digitalnog zapisa.
                                        </p>

                                        <pre><code>
                SNR ≈ 6.02n + 1.76 dB
                            </code></pre>

                                        <p>
                                            gde je n broj bitova kvantizacije.
                                        </p>

                                        <p>
                                            Primer:
                                        </p>

                                        <ul class="styled-list">
                                            <li>8-bit → ≈ 49.9 dB</li>
                                            <li>16-bit → ≈ 98 dB</li>
                                        </ul>

                                    </div>
                                </section>

                                <!-- 7 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">7. Analogno-digitalna konverzija (ADC)</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            ADC (Analog to Digital Converter) vrši:
                                        </p>

                                        <ul class="styled-list">
                                            <li>Uzorkovanje</li>
                                            <li>Kvantizaciju</li>
                                            <li>Kodiranje u binarni zapis</li>
                                        </ul>

                                        <p>
                                            Proces:
                                        </p>

                                        <pre><code>
                Analogni signal → Sample & Hold → Kvantizer → Binarni izlaz
                            </code></pre>

                                    </div>
                                </section>

                                <!-- 8 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">8. Digitalno-analogna konverzija (DAC)</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            DAC vrši obrnut proces — pretvara digitalni zapis
                                            nazad u analogni signal.
                                        </p>

                                        <p>
                                            Koristi interpolaciju i rekonstrukcioni filter
                                            za uklanjanje visokofrekventnih komponenti.
                                        </p>

                                    </div>
                                </section>

                                <!-- 9 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">9. Primena u multimediji</h2>
                                    <div class="lection-section__content">

                                        <ul class="styled-list">
                                            <li>Audio snimanje (44.1 kHz, 48 kHz)</li>
                                            <li>Digitalni video</li>
                                            <li>Obrada slike</li>
                                            <li>Kompresija</li>
                                        </ul>

                                        <p>
                                            Bez pravilne digitalizacije, svi kasniji procesi
                                            (kompresija, obrada, streaming) gube kvalitet.
                                        </p>

                                    </div>
                                </section>

                                <!-- ZAKLJUČAK -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">Zaključak</h2>
                                    <div class="lection-section__content">

                                        <p>
                                            Digitalizacija signala je osnova svih savremenih
                                            multimedijalnih sistema.
                                        </p>

                                        <div class="highlight-box">
                                            Kvalitet digitalnog zapisa zavisi od:
                                            frekvencije uzorkovanja, broja bitova i pravilne filtracije.
                                        </div>

                                    </div>
                                </section>

                            </div>

                            <!-- ===============================
                     NAVIGACIJA IZMEĐU LEKCIJA
                =============================== -->
                            <nav class="lection-nav">
                                <% if (navigation.prev) { %>
                                    <a href="/multimedijalne-aplikacije/lekcija/<%= navigation.prev.slug %>"
                                        class="lection-nav__link lection-nav__link--prev">
                                        <span class="nav-arrow">←</span>
                                        <span class="nav-text">
                                            <span class="nav-label">Prethodna lekcija</span>
                                            <span class="nav-title">
                                                <%= navigation.prev.title %>
                                            </span>
                                        </span>
                                    </a>
                                    <% } else { %>
                                        <a href="/multimedijalne-aplikacije"
                                            class="lection-nav__link lection-nav__link--prev">
                                            <span class="nav-arrow">←</span>
                                            <span class="nav-text">
                                                <span class="nav-label">Nazad na</span>
                                                <span class="nav-title">početnu predmeta</span>
                                            </span>
                                        </a>
                                        <% } %>

                                            <% if (navigation.next) { %>
                                                <a href="/multimedijalne-aplikacije/lekcija/<%= navigation.next.slug %>"
                                                    class="lection-nav__link lection-nav__link--next">
                                                    <span class="nav-text">
                                                        <span class="nav-label">Sledeća lekcija</span>
                                                        <span class="nav-title">
                                                            <%= navigation.next.title %>
                                                        </span>
                                                    </span>
                                                    <span class="nav-arrow">→</span>
                                                </a>
                                                <% } %>
                            </nav>

                        </article>

                        <% } %>

            </main>
        </div>

        <%- include('../../../includes/end') %>