<%- include('../../includes/head', { title: 'Materijali | Teorija Sistema i Informacija' }) %>

<main class="subject-page">
    <%- include('../../includes/navigation', { active: 'teorija-sistema' }) %>

    <section class="subject-hero subject-hero--small">
        <div class="container">
            <h1 class="subject-title">Materijali za preuzimanje</h1>
            <p class="subject-subtitle">
                Prezentacije i materijali dostupni prema planu nastave
            </p>
        </div>
    </section>

    <section class="section">
        <div class="container">

            <hr class="section-divider">

            <% if (!materials || materials.length === 0) { %>

                <div class="empty-state">
                    <div class="empty-state-icon">📂</div>
                    <p class="empty-state-title">Nema dostupnih materijala</p>
                    <p class="empty-state-small">
                        Materijali će biti objavljeni tokom semestra.
                    </p>
                </div>

            <% } else { %>

                <div class="materials-grid">

                <% materials.forEach(item => { %>

                    <div class="card <%= item.available ? '' : 'card--muted' %>">

                        <!-- HEADER -->
                        <div class="card-header">
                            <strong><%= item.label %></strong>

                            <span>
                                <% if (item.available) { %>
                                    ✅ Dostupno
                                <% } else { %>
                                    🔒 Zaključano
                                <% } %>
                            </span>
                        </div>

                        <!-- BODY -->
                        <div class="card-body">
                            <h3><%= item.title %></h3>

                            <% if (item.description) { %>
                                <p class="card-description"><%= item.description %></p>
                            <% } %>

                            <p class="card-date">
                                📅 <%= item.formattedDate %>
                            </p>
                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer">
                            <% if (item.available) { %>
                                <a
                                    href="<%= item.downloadPath %>"
                                    class="btn btn--primary"
                                    download
                                >
                                    ⬇ Preuzmi materijal
                                </a>
                            <% } else { %>
                                <button class="btn btn--disabled" disabled>
                                    Dostupno od <%= item.formattedDate %>
                                </button>
                            <% } %>
                        </div>

                    </div>

                <% }) %>

                </div>

            <% } %>

        </div>
    </section>
</main>

<%- include('../../includes/end') %>