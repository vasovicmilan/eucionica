<%- include('../../../includes/head', { title: lection.title, pageDescription: lection.description, pageStyles:
    pageStyles }) %>

    <%- include('../../../includes/navigation', { active: 'multimedijalne-aplikacije' }) %>

        <div class="lection-container">
            <!-- SIDEBAR -->
            <aside class="lection-sidebar">
                <%- include('../includes/navigation', { lections: lections, currentSlug: lection.slug }) %>
            </aside>

            <!-- CONTENT -->
            <main class="lection-content">

                <!-- ===============================
             LEKCIJA NIJE DOSTUPNA
        =============================== -->
                <% if (!lection.available) { %>

                    <div class="lection-locked">
                        <div class="lection-locked__icon">🔒</div>
                        <h1 class="lection-locked__title">Lekcija još nije dostupna</h1>
                        <p class="lection-locked__text">
                            Ova lekcija postaje dostupna
                            <strong>
                                <%= lection.formattedDate %>
                            </strong>.
                        </p>
                        <p class="lection-locked__text">Jedna lekcija se otključava svake nedelje.</p>
                        <a href="/multimedijalne-aplikacije" class="btn btn--primary btn--large">
                            Nazad na predmet
                        </a>
                    </div>

                    <!-- ===============================
             LEKCIJA JE DOSTUPNA
        =============================== -->
                    <% } else { %>

                        <article class="lection">

                            <!-- HEADER -->
                            <header class="lection__header">
                                <div class="lection__meta">
                                    <span class="lection__badge lection__badge--week">
                                        <span class="badge-icon">📅</span>
                                        Nedelja <%= lection.week %>
                                    </span>
                                    <span class="lection__badge lection__badge--date">
                                        <span class="badge-icon">📌</span>
                                        <%= lection.formattedDate %>
                                    </span>
                                </div>

                                <h1 class="lection__title">
                                    <%= lection.title %>
                                </h1>

                                <% if (lection.description) { %>
                                    <p class="lection__description">
                                        <%= lection.description %>
                                    </p>
                                    <% } %>
                                        <div class="project-note">

                                            ⚠️ Ovo je kratak pregled lekcije, nije zamena za prezentacije!

                                        </div>
                            </header>

                            <!-- ===============================
                     SADRŽAJ LEKCIJE
                =============================== -->
                            <div class="lection__content">

                                <!-- 1 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">1. Slojevi u digitalnoj obradi slike</h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Slojevi (Layers) predstavljaju osnovni princip rada u modernim
                                            programima za obradu slike kao što su Photoshop ili GIMP.
                                        </p>

                                        <p>
                                            Omogućavaju da se različiti elementi slike organizuju u
                                            nezavisne nivoe koji se mogu uređivati bez uticaja na ostatak slike.
                                        </p>

                                        <div class="highlight-box">
                                            Rad sa slojevima omogućava <strong>nedestruktivnu obradu slike</strong>,
                                            što znači da originalna slika ostaje sačuvana.
                                        </div>

                                        <p>Svaki sloj može sadržati:</p>

                                        <ul class="styled-list">
                                            <li>fotografiju</li>
                                            <li>tekst</li>
                                            <li>grafičke elemente</li>
                                            <li>efekte</li>
                                        </ul>

                                    </div>
                                </section>


                                <!-- 2 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">2. Tipovi slojeva</h2>

                                    <div class="lection-section__content">

                                        <p>U programima za obradu slike postoji više različitih vrsta slojeva:</p>

                                        <ul class="styled-list">
                                            <li><strong>Background layer</strong> – osnovni sloj slike</li>
                                            <li><strong>Image layer</strong> – sloj koji sadrži fotografiju</li>
                                            <li><strong>Text layer</strong> – sloj koji sadrži tekst</li>
                                            <li><strong>Adjustment layer</strong> – sloj za korekciju boja</li>
                                            <li><strong>Shape layer</strong> – sloj sa vektorskim oblicima</li>
                                        </ul>

                                        <div class="highlight-box">
                                            Profesionalni dizajneri koriste veliki broj slojeva
                                            kako bi projekat bio organizovan i lak za izmene.
                                        </div>

                                    </div>
                                </section>


                                <!-- 3 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">3. Blend modovi</h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Blend modovi određuju način na koji se pikseli jednog sloja
                                            kombinuju sa pikselima slojeva ispod njega.
                                        </p>

                                        <p>Najčešće korišćeni modovi su:</p>

                                        <ul class="styled-list">
                                            <li>Normal</li>
                                            <li>Multiply</li>
                                            <li>Screen</li>
                                            <li>Overlay</li>
                                            <li>Soft Light</li>
                                        </ul>

                                        <div class="highlight-box">
                                            Multiply mod se često koristi za senke,
                                            dok Screen mod služi za osvetljavanje slike.
                                        </div>

                                    </div>
                                </section>


                                <!-- 4 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">4. Maske slojeva</h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Maske slojeva omogućavaju kontrolu vidljivosti određenih
                                            delova slike bez trajnog brisanja sadržaja.
                                        </p>

                                        <p>Princip rada maski:</p>

                                        <ul class="styled-list">
                                            <li><strong>belo</strong> – vidljivo</li>
                                            <li><strong>crno</strong> – sakriveno</li>
                                            <li><strong>sivo</strong> – delimična transparentnost</li>
                                        </ul>

                                        <div class="highlight-box">
                                            Maske su ključne za profesionalnu foto manipulaciju
                                            i kombinovanje više fotografija u jednu kompoziciju.
                                        </div>

                                    </div>
                                </section>


                                <!-- 5 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">5. Selekcije</h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Selekcije omogućavaju da izaberemo određeni deo slike
                                            na koji će se primeniti obrada.
                                        </p>

                                        <p>Najčešći alati:</p>

                                        <ul class="styled-list">
                                            <li>Rectangular Marquee</li>
                                            <li>Lasso Tool</li>
                                            <li>Magic Wand</li>
                                            <li>Quick Selection Tool</li>
                                            <li>Pen Tool</li>
                                        </ul>

                                    </div>
                                </section>


                                <!-- 6 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">6. Retuširanje fotografija</h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Retuširanje predstavlja proces uklanjanja neželjenih
                                            elemenata i poboljšanja kvaliteta fotografije.
                                        </p>

                                        <ul class="styled-list">
                                            <li>Clone Stamp Tool</li>
                                            <li>Healing Brush</li>
                                            <li>Spot Healing Brush</li>
                                            <li>Patch Tool</li>
                                        </ul>

                                        <div class="highlight-box">
                                            Retuširanje treba koristiti umereno kako bi fotografija
                                            zadržala prirodan izgled.
                                        </div>

                                    </div>
                                </section>


                                <!-- 7 -->
                                <section class="lection-section">
                                    <h2 class="lection-section__title">7. Priprema grafike za web i štampu</h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Nakon obrade slike potrebno je pripremiti grafiku
                                            u zavisnosti od krajnje namene.
                                        </p>

                                        <h3>Za web</h3>

                                        <ul class="styled-list">
                                            <li>rezolucija 72–96 PPI</li>
                                            <li>RGB kolor model</li>
                                            <li>JPEG ili PNG format</li>
                                        </ul>

                                        <h3>Za štampu</h3>

                                        <ul class="styled-list">
                                            <li>rezolucija 300 DPI</li>
                                            <li>CMYK kolor model</li>
                                            <li>TIFF ili visokokvalitetni JPEG</li>
                                        </ul>

                                        <div class="highlight-box">
                                            Slika koja izgleda dobro na ekranu često neće biti
                                            dovoljno kvalitetna za štampu ako nije pripremljena
                                            u odgovarajućoj rezoluciji.
                                        </div>

                                    </div>
                                </section>

                            </div>

                            <!-- ===============================
                     NAVIGACIJA IZMEĐU LEKCIJA
                =============================== -->
                            <nav class="lection-nav">
                                <% if (navigation.prev) { %>
                                    <a href="/multimedijalne-aplikacije/lekcija/<%= navigation.prev.slug %>"
                                        class="lection-nav__link lection-nav__link--prev">
                                        <span class="nav-arrow">←</span>
                                        <span class="nav-text">
                                            <span class="nav-label">Prethodna lekcija</span>
                                            <span class="nav-title">
                                                <%= navigation.prev.title %>
                                            </span>
                                        </span>
                                    </a>
                                    <% } else { %>
                                        <a href="/multimedijalne-aplikacije"
                                            class="lection-nav__link lection-nav__link--prev">
                                            <span class="nav-arrow">←</span>
                                            <span class="nav-text">
                                                <span class="nav-label">Nazad na</span>
                                                <span class="nav-title">početnu predmeta</span>
                                            </span>
                                        </a>
                                        <% } %>

                                            <% if (navigation.next) { %>
                                                <a href="/multimedijalne-aplikacije/lekcija/<%= navigation.next.slug %>"
                                                    class="lection-nav__link lection-nav__link--next">
                                                    <span class="nav-text">
                                                        <span class="nav-label">Sledeća lekcija</span>
                                                        <span class="nav-title">
                                                            <%= navigation.next.title %>
                                                        </span>
                                                    </span>
                                                    <span class="nav-arrow">→</span>
                                                </a>
                                                <% } %>
                            </nav>

                        </article>

                        <% } %>

            </main>
        </div>

        <%- include('../../../includes/end') %>