<%- include('../../../includes/head', { title: lection.title, pageDescription: lection.description, pageStyles:
    pageStyles }) %>

    <%- include('../../../includes/navigation', { active: 'teorija-sistema' }) %>

        <div class="lection-container">

            <aside class="lection-sidebar">
                <%- include('../includes/navigation', { lections: lections, currentSlug: lection.slug }) %>
            </aside>

            <main class="lection-content">

                <% if (!lection.available) { %>

                    <div class="lection-locked">

                        <div class="lection-locked__icon">🔒</div>

                        <h1 class="lection-locked__title">
                            Lekcija još nije dostupna
                        </h1>

                        <p class="lection-locked__text">
                            Ova lekcija postaje dostupna
                            <strong>
                                <%= lection.formattedDate %>
                            </strong>.
                        </p>

                        <p class="lection-locked__text">
                            Jedna lekcija se otključava svake nedelje.
                        </p>

                        <a href="/teorija-sistema" class="btn btn--primary btn--large">
                            Nazad na predmet
                        </a>

                    </div>

                    <% } else { %>

                        <article class="lection">

                            <header class="lection__header">

                                <div class="lection__meta">

                                    <span class="lection__badge lection__badge--week">
                                        📅 Nedelja <%= lection.week %>
                                    </span>

                                    <span class="lection__badge lection__badge--date">
                                        📌 <%= lection.formattedDate %>
                                    </span>

                                </div>

                                <h1 class="lection__title">
                                    <%= lection.title %>
                                </h1>

                                <% if (lection.description) { %>
                                    <p class="lection__description">
                                        <%= lection.description %>
                                    </p>
                                    <% } %>
                                        <div class="project-note">

                                            ⚠️ Ovo je kratak pregled lekcije, nije zamena za prezentacije!

                                        </div>
                            </header>



                            <div class="lection__content">



                                <!-- SPREGE -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Sprege u sistemu
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Analiza sprega u sistemu omogućava razumevanje unutrašnjih
                                            karakteristika sistema.
                                        </p>

                                        <p>
                                            Fokus se pomera sa posmatranja sistema kao celine
                                            na njegove elemente i veze između elemenata.
                                        </p>

                                        <ul class="list list--icons">

                                            <li class="list__item">
                                                <span class="list__icon">🧩</span>
                                                elementi sistema
                                            </li>

                                            <li class="list__item">
                                                <span class="list__icon">🔗</span>
                                                veze između elemenata
                                            </li>

                                            <li class="list__item">
                                                <span class="list__icon">⚙️</span>
                                                ponašanje elemenata
                                            </li>

                                            <li class="list__item">
                                                <span class="list__icon">↔️</span>
                                                ulazi i izlazi elemenata
                                            </li>

                                        </ul>

                                    </div>

                                </section>



                                <!-- KATEGORIJE VEZA -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Kategorije veza u sistemu
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            U analizi sistema razlikuju se dve osnovne kategorije veza:
                                        </p>

                                        <ul class="list">

                                            <li>veza između celine i elemenata</li>
                                            <li>veza između samih elemenata sistema</li>

                                        </ul>

                                    </div>

                                </section>



                                <!-- CELINA I ELEMENTI -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Veza između celine i elemenata
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Veza između celine i elemenata posmatra se kroz
                                            različite nivoe agregacije sistema.
                                        </p>

                                        <p>
                                            Svaki kriterijum agregacije dovodi do
                                            određenog načina dekompozicije sistema.
                                        </p>

                                        <p class="formula">
                                            S = { S₁, S₂, … , Sₖ }
                                        </p>

                                        <p class="note">
                                            Sistem se može posmatrati kao skup svih
                                            relevantnih dekompozicionih struktura.
                                        </p>

                                    </div>

                                </section>



                                <!-- VEZE IZMEDJU ELEMENATA -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Veze između elemenata
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Ispitivanje odnosa između elemenata sistema
                                            odvija se u dve faze:
                                        </p>

                                        <ol class="list">

                                            <li>
                                                utvrđivanje da li postoji veza između elemenata
                                                (statički odnosi)
                                            </li>

                                            <li>
                                                analiza karakteristika veze
                                                (intenzitet, ponašanje, promene kroz vreme)
                                            </li>

                                        </ol>

                                    </div>

                                </section>



                                <!-- ELEMENTI I RELACIJE -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Elementi i relacije sistema
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Elementi predstavljaju osnovne komponente sistema,
                                            dok relacije predstavljaju veze između njih.
                                        </p>

                                        <p class="formula">
                                            E = {e₁, e₂, e₃, … , eₙ}
                                        </p>

                                        <ul class="list">

                                            <li><strong>E</strong> – skup elemenata sistema</li>
                                            <li><strong>n</strong> – broj elemenata sistema</li>

                                        </ul>

                                        <p class="formula">
                                            R = {r₁, r₂, r₃, … , rₘ}
                                        </p>

                                        <ul class="list">

                                            <li><strong>R</strong> – skup relacija</li>
                                            <li><strong>m</strong> – broj relacija</li>

                                        </ul>

                                    </div>

                                </section>



                                <!-- STATICKA STRUKTURA -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Statička struktura sistema
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Statička struktura predstavlja skup svih relacija
                                            između elemenata sistema.
                                        </p>

                                        <p class="formula">
                                            G = G₁ ∪ G₂ ∪ … ∪ Gₖ
                                        </p>

                                        <p>
                                            Svaki aspekt posmatranja daje određenu strukturu
                                            odnosa između elemenata sistema.
                                        </p>

                                    </div>

                                </section>



                                <!-- RELACIJE -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Jednostruke i višestruke relacije
                                    </h2>

                                    <div class="lection-section__content">

                                        <ul class="list list--icons">

                                            <li class="list__item">
                                                <span class="list__icon">➖</span>
                                                jednostruke relacije
                                            </li>

                                            <li class="list__item">
                                                <span class="list__icon">➕</span>
                                                višestruke relacije
                                            </li>

                                        </ul>

                                        <p class="formula">
                                            r₁ = (eᵢ , eⱼ)
                                        </p>

                                        <p>
                                            Kod višestrukih relacija isti par elemenata
                                            može imati više različitih veza.
                                        </p>

                                    </div>

                                </section>



                                <!-- GRAFOVI -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Grafičko predstavljanje strukture
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Struktura sistema često se predstavlja pomoću grafova.
                                        </p>

                                        <div class="tech-grid">

                                            <div class="tech-item">
                                                🔵 Čvorovi (elementi)
                                            </div>

                                            <div class="tech-item">
                                                ➡️ Lukovi (relacije)
                                            </div>

                                        </div>

                                        <p>
                                            Grafički prikaz omogućava lakše razumevanje
                                            strukture sistema.
                                        </p>

                                    </div>

                                </section>



                                <!-- MATRICE -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Matrični prikaz strukture
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Pored grafova, struktura sistema može se
                                            predstaviti i pomoću matrica.
                                        </p>

                                        <p class="highlight">
                                            Najčešće se koristi incidentna matrica.
                                        </p>

                                    </div>

                                </section>



                                <!-- INCIDENTNA MATRICA -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Incidentna matrica
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Incidentna matrica prikazuje vezu između
                                            elemenata sistema i relacija između njih.
                                        </p>

                                        <p>
                                            Koristi se u analizi strukture sistema.
                                        </p>

                                    </div>

                                </section>



                                <!-- DINAMICKE STRUKTURE -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Dinamičke strukture sistema
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Dinamičke strukture predstavljaju
                                            usmerene grafove.
                                        </p>

                                        <p class="note">
                                            Relacije između elemenata imaju određeni smer.
                                        </p>

                                    </div>

                                </section>



                                <!-- MATRICE PRETHODJENJA -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Matrice prethodjenja
                                    </h2>

                                    <div class="lection-section__content">

                                        <p>
                                            Koriste se za analizu dinamičkih struktura sistema.
                                        </p>

                                        <p class="formula">
                                            M₀₀ = M₀₁ × M₁₀
                                        </p>

                                        <p class="formula">
                                            M₁₁ = M₁₀ × M₀₁
                                        </p>

                                    </div>

                                </section>



                                <!-- STRUKTURE SISTEMA -->

                                <section class="lection-section">

                                    <h2 class="lection-section__title">
                                        Strukture sistema
                                    </h2>

                                    <div class="lection-section__content">

                                        <ul class="list list--icons">

                                            <li class="list__item">
                                                <span class="list__icon">➡️</span>
                                                redno povezani elementi
                                            </li>

                                            <li class="list__item">
                                                <span class="list__icon">🔀</span>
                                                paralelno povezani elementi
                                            </li>

                                        </ul>

                                        <p>
                                            Kod paralelnih struktura mogu postojati:
                                        </p>

                                        <ul class="list">

                                            <li>razvodne veze</li>
                                            <li>odvodne veze</li>

                                        </ul>

                                    </div>

                                </section>



                            </div>



                            <nav class="lection-nav">

                                <% if (navigation.prev) { %>

                                    <a href="/teorija-sistema/lekcija/<%= navigation.prev.slug %>"
                                        class="lection-nav__link lection-nav__link--prev">

                                        <span class="nav-arrow">←</span>

                                        <span class="nav-text">
                                            <span class="nav-label">Prethodna lekcija</span>
                                            <span class="nav-title">
                                                <%= navigation.prev.title %>
                                            </span>
                                        </span>

                                    </a>

                                    <% } else { %>

                                        <a href="/teorija-sistema" class="lection-nav__link lection-nav__link--prev">

                                            <span class="nav-arrow">←</span>

                                            <span class="nav-text">
                                                <span class="nav-label">Nazad na</span>
                                                <span class="nav-title">početnu predmeta</span>
                                            </span>

                                        </a>

                                        <% } %>



                                            <% if (navigation.next) { %>

                                                <a href="/teorija-sistema/lekcija/<%= navigation.next.slug %>"
                                                    class="lection-nav__link lection-nav__link--next">

                                                    <span class="nav-text">
                                                        <span class="nav-label">Sledeća lekcija</span>
                                                        <span class="nav-title">
                                                            <%= navigation.next.title %>
                                                        </span>
                                                    </span>

                                                    <span class="nav-arrow">→</span>

                                                </a>

                                                <% } %>

                            </nav>

                        </article>

                        <% } %>

            </main>

        </div>

        <%- include('../../../includes/end') %>