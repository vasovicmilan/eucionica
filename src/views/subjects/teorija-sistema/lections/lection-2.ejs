<%- include('../../../includes/head', { title: lection.title, pageDescription: lection.description, pageStyles:
    pageStyles }) %>

    <%- include('../../../includes/navigation', { active: 'teorija-sistema' }) %>

        <div class="lection-container">

            <!-- SIDEBAR -->
            <aside class="lection-sidebar">
                <%- include('../includes/navigation', { lections: lections, currentSlug: lection.slug }) %>
            </aside>

            <!-- CONTENT -->
            <main class="lection-content">

                <% if (!lection.available) { %>

                    <div class="lection-locked">
                        <div class="lection-locked__icon">🔒</div>

                        <h1 class="lection-locked__title">
                            Lekcija još nije dostupna
                        </h1>

                        <p class="lection-locked__text">
                            Ova lekcija postaje dostupna
                            <strong>
                                <%= lection.formattedDate %>
                            </strong>.
                        </p>

                        <p class="lection-locked__text">
                            Jedna lekcija se otključava svake nedelje.
                        </p>

                        <a href="/teorija-sistema" class="btn btn--primary btn--large">
                            Nazad na predmet
                        </a>
                    </div>

                    <% } else { %>

                        <article class="lection">

                            <!-- HEADER -->
                            <header class="lection__header">

                                <div class="lection__meta">

                                    <span class="lection__badge lection__badge--week">
                                        📅 Nedelja <%= lection.week %>
                                    </span>

                                    <span class="lection__badge lection__badge--date">
                                        📌 <%= lection.formattedDate %>
                                    </span>

                                </div>

                                <h1 class="lection__title">
                                    <%= lection.title %>
                                </h1>

                                <% if (lection.description) { %>
                                    <p class="lection__description">
                                        <%= lection.description %>
                                    </p>
                                    <% } %>
                                        <div class="project-note">

                                            ⚠️ Ovo je kratak pregled lekcije, nije zamena za prezentacije!

                                        </div>
                            </header>



                            <!-- CONTENT -->
                            <div class="lection__content">

                                <% if (lection.slug==="definicija-i-struktura-sistema" ) { %>



                                    <!-- UVOD -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Sistem
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Teorija sistema, kao samostalna zaokružena disciplina,
                                                predstavlja važan korak u razvoju nauke i naučnih
                                                istraživanja.
                                            </p>

                                            <p>
                                                Umesto jednostavnih analitičkih i linearnih metoda
                                                istraživanja, u centar pažnje dolazi proučavanje
                                                ukupnosti sistema — njegovih globalnih karakteristika,
                                                strukture i ponašanja.
                                            </p>

                                            <p class="highlight">
                                                Fokus teorije sistema je razumevanje celokupnog
                                                funkcionisanja složenih celina.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- DEFINICIJA SISTEMA -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Definicija sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                U mnogim naukama, naročito eksperimentalnim,
                                                definisanje pojmova nije od presudnog značaja.
                                            </p>

                                            <p>
                                                Međutim, formalizovane naučne discipline
                                                zahtevaju jasno definisane osnovne pojmove.
                                            </p>

                                            <p class="note">
                                                Zato je važno precizno definisati pojam sistema.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- PITANJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Ključno pitanje
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Postavlja se pitanje:
                                            </p>

                                            <p class="highlight">
                                                Kako definisati sistem tako da definicija
                                                bude dovoljno opšta, ali istovremeno i
                                                praktična za primenu?
                                            </p>

                                        </div>

                                    </section>



                                    <!-- DEFINICIJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Definicije sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <div class="comparison-grid">

                                                <div class="comparison-item">

                                                    <div class="comparison-icon">🧩</div>

                                                    <h3>Definicija 1</h3>

                                                    <p>
                                                        Sistem je totalni skup interaktivnih
                                                        elemenata posmatranih na određenom
                                                        nivou posmatranja.
                                                    </p>

                                                    <p>
                                                        Sistem može predstavljati i skup
                                                        elemenata koji su nedeljivi u okviru
                                                        datog kognitivnog pristupa.
                                                    </p>

                                                </div>

                                                <div class="comparison-item">

                                                    <div class="comparison-icon">🌐</div>

                                                    <h3>Definicija 2</h3>

                                                    <p>
                                                        Sistem je celina elemenata
                                                        f1, f2, f3 ... fn koji su
                                                        međusobno u interakciji.
                                                    </p>

                                                    <p>
                                                        (Ludwig von Bertalanffy)
                                                    </p>

                                                </div>

                                            </div>

                                            <p class="note">
                                                Sistem se može definisati i kao uređeni skup
                                                elemenata koji su međusobno povezani i čine
                                                jednu celinu – totalitet. (Sadovskij)
                                            </p>

                                        </div>

                                    </section>



                                    <!-- RELACIJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Relacije između elemenata
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Nakon identifikacije elemenata sistema,
                                                sledeći korak je identifikacija relacija
                                                između njih.
                                            </p>

                                            <p>
                                                Elementi sistema ne mogu se razumeti
                                                bez razumevanja odnosa koji među njima
                                                postoje.
                                            </p>

                                            <ul class="list list--icons">

                                                <li class="list__item">
                                                    <span class="list__icon">🔗</span>
                                                    odnosi između elemenata
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">📈</span>
                                                    intenzitet međusobnog uticaja
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">⚡</span>
                                                    uzročno-posledične veze
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">🔄</span>
                                                    međusobna zavisnost
                                                </li>

                                            </ul>

                                        </div>

                                    </section>



                                    <!-- OKRUŽENJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Okruženje sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Sistem je izdvojena celina koja je u
                                                interakciji sa okruženjem.
                                            </p>

                                            <p>
                                                Okruženje obuhvata sve spoljne faktore
                                                koji mogu uticati na sistem.
                                            </p>

                                            <p class="note">
                                                Sistem i njegovo okruženje zajedno čine
                                                širi totalitet.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- HIJERARHIJA -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Hijerarhijska građa sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Pri analizi sistema mora se voditi računa
                                                o njegovoj hijerarhijskoj strukturi.
                                            </p>

                                            <ul class="list">

                                                <li>
                                                    elementi sistema mogu biti deljivi
                                                </li>

                                                <li>
                                                    pojedini elementi mogu se posmatrati
                                                    kao zasebni sistemi (podsistemi)
                                                </li>

                                                <li>
                                                    relacije postoje i između podsistema
                                                </li>

                                            </ul>

                                            <p class="note">
                                                Hijerarhijska struktura odnosi se i na
                                                elemente i na relacije između njih.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- ZAKLJUČAK -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Šta dobijamo?
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Sistem sadrži:
                                            </p>

                                            <ul class="list list--icons">

                                                <li class="list__item">
                                                    <span class="list__icon">🧩</span>
                                                    skup elemenata
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">🔗</span>
                                                    skup relacija između elemenata
                                                </li>

                                            </ul>

                                            <p>
                                                Kao celina, sistem poseduje:
                                            </p>

                                            <ul class="list">

                                                <li>uređenost</li>
                                                <li>organizovanost</li>
                                                <li>strukturu</li>

                                            </ul>

                                        </div>

                                    </section>



                                    <% } %>

                            </div>



                            <!-- NAVIGATION -->
                            <nav class="lection-nav">

                                <% if (navigation.prev) { %>

                                    <a href="/teorija-sistema/lekcija/<%= navigation.prev.slug %>"
                                        class="lection-nav__link lection-nav__link--prev">

                                        <span class="nav-arrow">←</span>

                                        <span class="nav-text">
                                            <span class="nav-label">
                                                Prethodna lekcija
                                            </span>

                                            <span class="nav-title">
                                                <%= navigation.prev.title %>
                                            </span>
                                        </span>

                                    </a>

                                    <% } else { %>

                                        <a href="/teorija-sistema" class="lection-nav__link lection-nav__link--prev">

                                            <span class="nav-arrow">←</span>

                                            <span class="nav-text">
                                                <span class="nav-label">
                                                    Nazad na
                                                </span>

                                                <span class="nav-title">
                                                    početnu predmeta
                                                </span>
                                            </span>

                                        </a>

                                        <% } %>



                                            <% if (navigation.next) { %>

                                                <a href="/teorija-sistema/lekcija/<%= navigation.next.slug %>"
                                                    class="lection-nav__link lection-nav__link--next">

                                                    <span class="nav-text">

                                                        <span class="nav-label">
                                                            Sledeća lekcija
                                                        </span>

                                                        <span class="nav-title">
                                                            <%= navigation.next.title %>
                                                        </span>

                                                    </span>

                                                    <span class="nav-arrow">→</span>

                                                </a>

                                                <% } %>

                            </nav>

                        </article>

                        <% } %>

            </main>

        </div>

        <%- include('../../../includes/end') %>