<%- include('../../../includes/head', { title: lection.title, pageDescription: lection.description, pageStyles:
    pageStyles }) %>

    <%- include('../../../includes/navigation', { active: 'teorija-sistema' }) %>

        <div class="lection-container">

            <aside class="lection-sidebar">
                <%- include('../includes/navigation', { lections: lections, currentSlug: lection.slug }) %>
            </aside>

            <main class="lection-content">

                <% if (!lection.available) { %>

                    <div class="lection-locked">
                        <div class="lection-locked__icon">🔒</div>

                        <h1 class="lection-locked__title">
                            Lekcija još nije dostupna
                        </h1>

                        <p class="lection-locked__text">
                            Ova lekcija postaje dostupna
                            <strong>
                                <%= lection.formattedDate %>
                            </strong>.
                        </p>

                        <p class="lection-locked__text">
                            Jedna lekcija se otključava svake nedelje.
                        </p>

                        <a href="/teorija-sistema" class="btn btn--primary btn--large">
                            Nazad na predmet
                        </a>
                    </div>

                    <% } else { %>

                        <article class="lection">

                            <header class="lection__header">

                                <div class="lection__meta">

                                    <span class="lection__badge lection__badge--week">
                                        📅 Nedelja <%= lection.week %>
                                    </span>

                                    <span class="lection__badge lection__badge--date">
                                        📌 <%= lection.formattedDate %>
                                    </span>

                                </div>

                                <h1 class="lection__title">
                                    <%= lection.title %>
                                </h1>

                                <% if (lection.description) { %>
                                    <p class="lection__description">
                                        <%= lection.description %>
                                    </p>
                                    <% } %>
                                        <div class="project-note">

                                            ⚠️ Ovo je kratak pregled lekcije, nije zamena za prezentacije!

                                        </div>
                            </header>



                            <div class="lection__content">

                                <% if (lection.slug==="stabilnost-i-ponasanje-sistema" ) { %>


                                    <!-- UVOD -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Odnos delova i celine
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                U analizi sistema često se proučava odnos između
                                                pojedinačnih elemenata i celine sistema.
                                            </p>

                                            <p>
                                                Najčešće se koriste dva pristupa:
                                            </p>

                                            <ul class="list list--icons">

                                                <li class="list__item">
                                                    <span class="list__icon">🔍</span>
                                                    Analitički pristup
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">🧩</span>
                                                    Sintetički pristup
                                                </li>

                                            </ul>

                                            <p class="note">
                                                Broj relacija između elemenata zavisi od broja elemenata sistema.
                                            </p>

                                            <p class="formula">
                                                v = n(n − 1)
                                            </p>

                                        </div>

                                    </section>



                                    <!-- TRANSFORMACIJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Vreme transformacija sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Svako preslikavanje ili transformacija sistema
                                                odvija se tokom određenog vremenskog intervala.
                                            </p>

                                            <p class="formula">
                                                Δt = t₂ − t₁
                                            </p>

                                            <p>
                                                Ova vremenska dimenzija je važna za analizu
                                                ponašanja sistema kroz vreme.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- TIPOVI ELEMENATA -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Tipovi elemenata sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                U sistemima može postojati veliki broj različitih
                                                tipova elemenata.
                                            </p>

                                            <div class="tech-grid">

                                                <div class="tech-item">➕ Aditivni elementi</div>

                                                <div class="tech-item">✖️ Elementi koji množe</div>

                                                <div class="tech-item">➖ Elementi koji oduzimaju</div>

                                                <div class="tech-item">➗ Elementi koji dele</div>

                                                <div class="tech-item">🔢 Elementi sa jednom promenljivom</div>

                                                <div class="tech-item">📊 Elementi sa više promenljivih</div>

                                            </div>

                                        </div>

                                    </section>



                                    <!-- STABILNOST -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Stabilnost sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Stabilnost sistema predstavlja osobinu sistema
                                                da zadrži određene karakteristike kroz vreme.
                                            </p>

                                            <p>
                                                U mnogim sistemima postoje određeni aspekti
                                                koji se ne menjaju — oni se nazivaju
                                                <strong>invarijantnim svojstvima</strong>.
                                            </p>

                                            <p class="highlight">
                                                Stabilni sistemi zadržavaju svoja osnovna
                                                svojstva uprkos promenama u okruženju.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- RAVNOTEZA -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Ravnotežna stanja sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Stanja sistema koja teže identičnim transformacijama
                                                nazivaju se <strong>ravnotežna stanja</strong>.
                                            </p>

                                            <p>
                                                Kod sistema sa vektorskim veličinama ravnoteža postoji
                                                kada sve koordinate vektora ostaju nepromenjene.
                                            </p>

                                            <p class="note">
                                                Ravnoteža znači da sistem nema tendenciju
                                                daljih promena stanja.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- CIKLICNOST -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Cikličnost sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Ravnotežni prostor predstavlja skup stanja
                                                koja se periodično ponavljaju.
                                            </p>

                                            <p>
                                                Ova pojava naziva se <strong>cikličnost sistema</strong>.
                                            </p>

                                            <p class="highlight">
                                                Sistemi sa cikličnim ponašanjem
                                                prolaze kroz iste sekvence stanja.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- SMETNJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Smetnje u sistemu
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Smetnja predstavlja spoljašnji ili unutrašnji
                                                uticaj koji menja stanje sistema.
                                            </p>

                                            <p>
                                                Stabilan sistem treba da bude u stanju
                                                da nakon smetnje ponovo dostigne
                                                svoje prethodno ravnotežno stanje.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- NESTABILNOST -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Nestabilna stanja
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Neka stanja sistema mogu biti nestabilna,
                                                što znači da i mala promena može dovesti
                                                do značajne promene ponašanja sistema.
                                            </p>

                                            <p class="formula">
                                                D(d), D(h)
                                            </p>

                                            <p>
                                                Ova stanja predstavljaju primere
                                                nestabilnih ravnotežnih stanja sistema.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- ZAKLJUCAK -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Zaključak
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Stabilnost sistema je ključni aspekt
                                                u analizi i projektovanju složenih sistema.
                                            </p>

                                            <p>
                                                Razumevanje ravnoteže, cikličnosti i
                                                uticaja smetnji omogućava bolje
                                                predviđanje ponašanja sistema.
                                            </p>

                                            <p class="highlight">
                                                Stabilni sistemi imaju sposobnost
                                                da se vrate u ravnotežu nakon poremećaja.
                                            </p>

                                        </div>

                                    </section>



                                    <% } %>

                            </div>



                            <nav class="lection-nav">

                                <% if (navigation.prev) { %>

                                    <a href="/teorija-sistema/lekcija/<%= navigation.prev.slug %>"
                                        class="lection-nav__link lection-nav__link--prev">

                                        <span class="nav-arrow">←</span>

                                        <span class="nav-text">
                                            <span class="nav-label">Prethodna lekcija</span>
                                            <span class="nav-title">
                                                <%= navigation.prev.title %>
                                            </span>
                                        </span>

                                    </a>

                                    <% } else { %>

                                        <a href="/teorija-sistema" class="lection-nav__link lection-nav__link--prev">

                                            <span class="nav-arrow">←</span>

                                            <span class="nav-text">
                                                <span class="nav-label">Nazad na</span>
                                                <span class="nav-title">početnu predmeta</span>
                                            </span>

                                        </a>

                                        <% } %>



                                            <% if (navigation.next) { %>

                                                <a href="/teorija-sistema/lekcija/<%= navigation.next.slug %>"
                                                    class="lection-nav__link lection-nav__link--next">

                                                    <span class="nav-text">

                                                        <span class="nav-label">
                                                            Sledeća lekcija
                                                        </span>

                                                        <span class="nav-title">
                                                            <%= navigation.next.title %>
                                                        </span>

                                                    </span>

                                                    <span class="nav-arrow">→</span>

                                                </a>

                                                <% } %>

                            </nav>

                        </article>

                        <% } %>

            </main>

        </div>

        <%- include('../../../includes/end') %>