<%- include('../../../includes/head', { title: lection.title, pageDescription: lection.description, pageStyles:
    pageStyles }) %>

    <%- include('../../../includes/navigation', { active: 'teorija-sistema' }) %>

        <div class="lection-container">

            <!-- SIDEBAR -->
            <aside class="lection-sidebar">
                <%- include('../includes/navigation', { lections: lections, currentSlug: lection.slug }) %>
            </aside>

            <main class="lection-content">

                <% if (!lection.available) { %>

                    <div class="lection-locked">
                        <div class="lection-locked__icon">🔒</div>

                        <h1 class="lection-locked__title">
                            Lekcija još nije dostupna
                        </h1>

                        <p class="lection-locked__text">
                            Ova lekcija postaje dostupna
                            <strong>
                                <%= lection.formattedDate %>
                            </strong>.
                        </p>

                        <p class="lection-locked__text">
                            Jedna lekcija se otključava svake nedelje.
                        </p>

                        <a href="/teorija-sistema" class="btn btn--primary btn--large">
                            Nazad na predmet
                        </a>
                    </div>

                    <% } else { %>

                        <article class="lection">

                            <header class="lection__header">

                                <div class="lection__meta">

                                    <span class="lection__badge lection__badge--week">
                                        📅 Nedelja <%= lection.week %>
                                    </span>

                                    <span class="lection__badge lection__badge--date">
                                        📌 <%= lection.formattedDate %>
                                    </span>

                                </div>

                                <h1 class="lection__title">
                                    <%= lection.title %>
                                </h1>

                                <% if (lection.description) { %>
                                    <p class="lection__description">
                                        <%= lection.description %>
                                    </p>
                                    <% } %>
                                        <div class="project-note">

                                            ⚠️ Ovo je kratak pregled lekcije, nije zamena za prezentacije!

                                        </div>
                            </header>



                            <div class="lection__content">

                                <% if (lection.slug==="modelovanje-i-klasifikacija-sistema" ) { %>


                                    <!-- UVOD -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Dalja diskusija o teoriji sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Pošto smo definisali pojam sistema, sada se fokusiramo
                                                na dalji razvoj teorije sistema i načine klasifikacije sistema.
                                            </p>

                                            <p>
                                                Cilj je produbljivanje razumevanja sistema kroz različite
                                                naučne pristupe i metode modelovanja.
                                            </p>

                                            <p class="highlight">
                                                Teorija sistema razvijala se kroz više različitih pravaca.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- PRAVCI RAZVOJA -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Pravci razvoja teorije sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <ul class="list list--icons">

                                                <li class="list__item">
                                                    <span class="list__icon">🌐</span>
                                                    Generalistički pravac razvoja
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">📐</span>
                                                    Matematičko–formalni pravac
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">🤝</span>
                                                    Interdisciplinarni razvoj
                                                </li>

                                            </ul>

                                        </div>

                                    </section>



                                    <!-- GENERALISTICKI -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Generalistički pristup
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Teorija sistema predstavlja opšti konceptualni model
                                                posmatranja složenih pojava.
                                            </p>

                                            <p>
                                                Ovaj pristup zahteva korišćenje opštih naučnih metoda
                                                koji nastaju sintezom više disciplina.
                                            </p>

                                            <p class="note">
                                                Na osnovu ovih znanja razvijaju se specijalističke discipline.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- MATEMATICKI -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Matematičko–formalni pravac
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Ovaj pravac koristi matematičke modele
                                                za opisivanje ponašanja sistema.
                                            </p>

                                            <ul class="list">
                                                <li>diskretna matematika</li>
                                                <li>teorija skupova</li>
                                                <li>apstraktna algebra</li>
                                            </ul>

                                            <p class="note">
                                                Primena je moguća kada se sistem može formalno opisati.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- INTERDISCIPLINARNI -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Interdisciplinarni pristup
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Fokus je na rešavanju kompleksnih problema
                                                koji zahtevaju saradnju više naučnih disciplina.
                                            </p>

                                            <p>
                                                Tipičan primer je sistem čovek–mašina.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- ISPITIVANJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Ispitivanje sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Proces upoznavanja sistema je cikličan.
                                            </p>

                                            <ul class="list">
                                                <li>definisanje sistema</li>
                                                <li>ispitivanje sistema</li>
                                                <li>ponovno definisanje</li>
                                            </ul>

                                            <p class="note">
                                                Svaka iteracija daje bolje razumevanje sistema.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- MODEL -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Modelovanje sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Modelovanje predstavlja preslikavanje realnog
                                                sistema na njegov model.
                                            </p>

                                            <p>
                                                Polazi se od poznatih karakteristika originala
                                                koje se prenose na model.
                                            </p>

                                        </div>

                                    </section>



                                    <!-- PRESLIKAVANJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Vrste preslikavanja
                                        </h2>

                                        <div class="lection-section__content">

                                            <div class="comparison-grid">

                                                <div class="comparison-item">
                                                    <div class="comparison-icon">📉</div>

                                                    <h3>Homomorfno</h3>

                                                    <p>
                                                        Model predstavlja pojednostavljenu
                                                        verziju sistema.
                                                    </p>

                                                </div>

                                                <div class="comparison-item">
                                                    <div class="comparison-icon">🪞</div>

                                                    <h3>Izomorfno</h3>

                                                    <p>
                                                        Model u potpunosti odgovara
                                                        originalnom sistemu.
                                                    </p>

                                                </div>

                                            </div>

                                        </div>

                                    </section>



                                    <!-- KLASIFIKACIJA -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Klasifikacija sistema
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Svrha klasifikacije je savladavanje kompleksnosti sistema.
                                            </p>

                                            <ul class="list">
                                                <li>globalna obeležja sistema</li>
                                                <li>unutrašnje karakteristike</li>
                                                <li>odnos sa okruženjem</li>
                                            </ul>

                                        </div>

                                    </section>



                                    <!-- NACIN NASTANKA -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Sistemi prema načinu nastanka
                                        </h2>

                                        <div class="lection-section__content">

                                            <div class="tech-grid">

                                                <div class="tech-item">🌿 Prirodni sistemi</div>

                                                <div class="tech-item">🏗️ Veštački sistemi</div>

                                                <div class="tech-item">🔄 Prelazni sistemi</div>

                                            </div>

                                        </div>

                                    </section>



                                    <!-- POJAVNI OBLIK -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Sistemi prema pojavnom obliku
                                        </h2>

                                        <div class="lection-section__content">

                                            <ul class="list">
                                                <li>Realni sistemi</li>
                                                <li>Apstraktni sistemi</li>
                                                <li>Kombinovani sistemi</li>
                                            </ul>

                                        </div>

                                    </section>



                                    <!-- SLOZENOST -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Sistemi prema složenosti
                                        </h2>

                                        <div class="lection-section__content">

                                            <ul class="list list--icons">

                                                <li class="list__item">
                                                    <span class="list__icon">⚙️</span>
                                                    Prosti sistemi
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">🧩</span>
                                                    Složeni sistemi
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">📊</span>
                                                    Veoma složeni sistemi
                                                </li>

                                                <li class="list__item">
                                                    <span class="list__icon">🌐</span>
                                                    Kompleksni sistemi
                                                </li>

                                            </ul>

                                        </div>

                                    </section>



                                    <!-- OKRUZENJE -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Sistemi prema odnosu sa okruženjem
                                        </h2>

                                        <div class="lection-section__content">

                                            <div class="tech-grid">

                                                <div class="tech-item">🔓 Otvoreni sistemi</div>

                                                <div class="tech-item">🔒 Zatvoreni sistemi</div>

                                                <div class="tech-item">↔️ Poluotvoreni sistemi</div>

                                            </div>

                                        </div>

                                    </section>



                                    <!-- ZAKLJUCAK -->
                                    <section class="lection-section">

                                        <h2 class="lection-section__title">
                                            Zaključak
                                        </h2>

                                        <div class="lection-section__content">

                                            <p>
                                                Klasifikacija sistema omogućava lakše razumevanje
                                                složenih sistema i njihovih karakteristika.
                                            </p>

                                            <p class="highlight">
                                                Modelovanje i klasifikacija predstavljaju ključne
                                                alate za proučavanje sistema.
                                            </p>

                                        </div>

                                    </section>



                                    <% } %>

                            </div>



                            <nav class="lection-nav">

                                <% if (navigation.prev) { %>

                                    <a href="/teorija-sistema/lekcija/<%= navigation.prev.slug %>"
                                        class="lection-nav__link lection-nav__link--prev">

                                        <span class="nav-arrow">←</span>

                                        <span class="nav-text">
                                            <span class="nav-label">
                                                Prethodna lekcija
                                            </span>

                                            <span class="nav-title">
                                                <%= navigation.prev.title %>
                                            </span>
                                        </span>

                                    </a>

                                    <% } else { %>

                                        <a href="/teorija-sistema" class="lection-nav__link lection-nav__link--prev">

                                            <span class="nav-arrow">←</span>

                                            <span class="nav-text">
                                                <span class="nav-label">Nazad na</span>
                                                <span class="nav-title">početnu predmeta</span>
                                            </span>

                                        </a>

                                        <% } %>



                                            <% if (navigation.next) { %>

                                                <a href="/teorija-sistema/lekcija/<%= navigation.next.slug %>"
                                                    class="lection-nav__link lection-nav__link--next">

                                                    <span class="nav-text">

                                                        <span class="nav-label">
                                                            Sledeća lekcija
                                                        </span>

                                                        <span class="nav-title">
                                                            <%= navigation.next.title %>
                                                        </span>

                                                    </span>

                                                    <span class="nav-arrow">→</span>

                                                </a>

                                                <% } %>

                            </nav>

                        </article>

                        <% } %>

            </main>

        </div>

        <%- include('../../../includes/end') %>